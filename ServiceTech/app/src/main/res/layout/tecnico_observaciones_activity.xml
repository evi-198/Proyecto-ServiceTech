<?xml version="1.0" encoding="utf-8"?>

<!--
    Pantalla de gestión de observaciones del técnico.
    Permite visualizar los servicios asignados y acceder a las observaciones
    relacionadas con cada servicio para su consulta y administración.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    tools:context=".ui.tecnico.observaciones.ObservacionesActivity">


    <!-- Encabezado principal de la pantalla -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Observaciones"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="16dp"/>


    <!--
        Lista de servicios asignados al técnico.
        Cada elemento representa un servicio disponible para consultar
        y gestionar sus observaciones asociadas.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerObservaciones"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        tools:listitem="@layout/tecnico_servicio_asignado_item"/>


    <!--
        Menú inferior de navegación del panel técnico.
        Proporciona acceso rápido a las secciones principales del módulo
        y permite cerrar la sesión actual.
    -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomMenuCard"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">


        <!-- Contenedor de opciones de navegación -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="4">


            <!--
                Acceso al inicio del panel técnico.
            -->
            <LinearLayout
                android:id="@+id/btnInicio"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/inicio_icono"
                    app:tint="#6B7280" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inicio"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

            </LinearLayout>


            <!--
                Acceso a la lista de servicios asignados
                para la gestión del técnico.
            -->
            <LinearLayout
                android:id="@+id/btnAsignados"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/clientes_icono"
                    app:tint="#6B7280" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Asignados"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

            </LinearLayout>


            <!--
                Acceso al módulo de reportes generados
                por el técnico.
            -->
            <LinearLayout
                android:id="@+id/btnReportes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/reporte_icono"
                    app:tint="#6B7280" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mis Reportes"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

            </LinearLayout>


            <!--
                Acción para cerrar la sesión del técnico
                y finalizar el acceso al sistema.
            -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/cerrar_sesion_icono"
                    app:tint="#6B7280" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cerrar Sesión"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

            </LinearLayout>


        </LinearLayout>

    </androidx.cardview.widget.CardView>


</LinearLayout>