<?xml version="1.0" encoding="utf-8"?>

<!-- Tarjeta utilizada para mostrar la información de una orden de servicio. -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true">

    <!-- Contenedor principal del contenido de la orden. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Encabezado que muestra el tipo de servicio y su estado. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtTipoOrden"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tipo de servicio"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtEstadoOrden"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:text="Estado"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_estado_pendiente" />
        </LinearLayout>

        <!-- Descripción de la orden de servicio. -->
        <TextView
            android:id="@+id/txtDescripcionOrden"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Descripción del servicio"
            android:textColor="#4B5563"
            android:textSize="14sp" />

        <!-- Información del cliente asociado a la orden. -->
        <TextView
            android:id="@+id/txtClienteOrden"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Cliente: Nombre"
            android:textColor="#6B7280"
            android:textSize="13sp" />

        <!-- Información del técnico asignado a la orden. -->
        <TextView
            android:id="@+id/txtTecnicoOrden"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Técnico: Sin asignar"
            android:textColor="#6B7280"
            android:textSize="13sp" />

        <!-- Botón para asignar un técnico a la orden de servicio. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAsignarTecnico"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_gravity="end"
            android:minWidth="0dp"
            android:paddingHorizontal="12dp"
            android:text="Asignar técnico"
            android:textAllCaps="false"
            android:textColor="#0F172A"
            app:icon="@drawable/tecnico_icono"
            app:iconPadding="6dp"
            app:iconTint="#0F172A" />
    </LinearLayout>

</androidx.cardview.widget.CardView>