<?xml version="1.0" encoding="utf-8"?>

<!--
    Ítem utilizado para mostrar el detalle de un servicio
    dentro del reporte generado por el técnico.
    Presenta información del cliente, estado, fechas, descripción
    y observaciones asociadas al servicio.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp">


    <!--
        Contenedor principal de la información del servicio.
        Organiza los datos mostrados dentro de la tarjeta del reporte.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">


        <!--
            Sección de identificación del servicio.
            Muestra el tipo de servicio registrado en el reporte.
        -->
        <TextView
            android:id="@+id/txtReporteTipo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#111827" />


        <!-- Información del cliente asociado al servicio -->
        <TextView
            android:id="@+id/txtReporteCliente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#4B5563"
            android:textSize="14sp" />


        <!--
            Estado actual del servicio.
            Permite identificar visualmente la situación del trabajo técnico.
        -->
        <TextView
            android:id="@+id/txtReporteEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_estado_pendiente" />


        <!-- Información relacionada con fechas del servicio -->
        <TextView
            android:id="@+id/txtReporteFechas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="12sp"
            android:textColor="#6B7280" />


        <!-- Descripción del trabajo solicitado por el cliente -->
        <TextView
            android:id="@+id/txtReporteDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#374151"
            android:textSize="14sp" />


        <!--
            Sección de observaciones del servicio.
            Indica la existencia de comentarios registrados
            durante la atención técnica.
        -->
        <TextView
            android:id="@+id/txtReporteObservacionesTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textStyle="bold"
            android:textColor="#1E40AF"
            android:textSize="13sp" />


        <!-- Detalle de observaciones asociadas al servicio -->
        <TextView
            android:id="@+id/txtReporteObservacionesDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#4B5563"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp" />


    </LinearLayout>

</androidx.cardview.widget.CardView>