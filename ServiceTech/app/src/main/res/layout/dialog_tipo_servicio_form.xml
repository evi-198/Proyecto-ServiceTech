<?xml version="1.0" encoding="utf-8"?>

<!--
    Formulario utilizado dentro de un cuadro de diálogo para registrar
    o editar la información de un tipo de servicio. Permite ingresar
    el nombre y la descripción correspondiente.
-->

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:padding="18dp">

    <!-- Sección que contiene los campos de ingreso de datos del tipo de servicio. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Campo para registrar o modificar el nombre del tipo de servicio. -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre del tipo de servicio">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtNombreTipoDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo para registrar o modificar la descripción del tipo de servicio. -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Descripción">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtDescripcionTipoDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>