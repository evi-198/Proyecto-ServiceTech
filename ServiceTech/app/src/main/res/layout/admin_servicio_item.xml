<?xml version="1.0" encoding="utf-8"?>

<!-- Tarjeta utilizada para mostrar la información de un tipo de servicio. -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true">

    <!-- Contenedor principal de la información del tipo de servicio. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Nombre del tipo de servicio. -->
        <TextView
            android:id="@+id/txtNombreTipo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre del tipo de servicio"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Descripción del tipo de servicio. -->
        <TextView
            android:id="@+id/txtDescripcionTipo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Descripción"
            android:textColor="#6B7280"
            android:textSize="14sp" />

        <!-- Contenedor de las acciones disponibles para el registro. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="end"
            android:orientation="horizontal">

            <!-- Botón para editar el tipo de servicio. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditarTipo"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingHorizontal="12dp"
                android:text="Editar"
                android:textAllCaps="false"
                android:textColor="#0F172A"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconTint="#0F172A" />

            <!-- Botón para eliminar el tipo de servicio. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminarTipo"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:minWidth="0dp"
                android:paddingHorizontal="12dp"
                android:text="Eliminar"
                android:textAllCaps="false"
                android:textColor="#DC2626"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconTint="#DC2626" />
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>