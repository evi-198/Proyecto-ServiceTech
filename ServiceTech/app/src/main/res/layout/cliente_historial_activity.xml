<?xml version="1.0" encoding="utf-8"?>

<!-- Pantalla que muestra el historial de servicios del cliente. -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.cliente.HistorialActivity">

    <!-- Título principal de la pantalla. -->
    <TextView
        android:id="@+id/txtTituloHistorial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Historial de Servicios"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:layout_marginStart="16dp"
        android:textColor="#000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Grupo de botones para filtrar el historial de servicios. -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:singleSelection="true"
        app:layout_constraintTop_toBottomOf="@id/txtTituloHistorial"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Botón para visualizar los servicios finalizados. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinalizados"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Finalizados"
            android:backgroundTint="@color/green"
            android:textColor="@android:color/white"/>

        <!-- Botón para visualizar los servicios cancelados. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelados"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancelados"
            android:backgroundTint="@color/green"
            android:textColor="@android:color/white"/>

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Lista donde se muestran los servicios del historial. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHistorial"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/toggleGroup"
        app:layout_constraintBottom_toTopOf="@id/bottomMenuCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/cliente_servicio_ver_estado_item" />

    <!-- Menú de navegación inferior del cliente. -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomMenuCard"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@android:color/white"
        app:layout_constraintBottom_toTopOf="@id/navBarDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Contenedor de las opciones de navegación. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="4"
            android:gravity="center"
            android:paddingVertical="4dp"
            android:baselineAligned="false">

            <!-- Opción para acceder al inicio. -->
            <LinearLayout
                android:id="@+id/btnInicio"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/iconInicio"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/inicio_icono"
                    android:contentDescription="Inicio"
                    app:tint="@color/menu_icon_color" />

                <TextView
                    android:id="@+id/textInicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inicio"
                    android:textColor="@color/menu_text_color"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Opción para acceder a la lista de servicios del cliente. -->
            <LinearLayout
                android:id="@+id/btnMisServicios"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/iconMisServicios"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/servicios_icono"
                    android:contentDescription="Mis Servicios"
                    app:tint="@color/menu_icon_color" />

                <TextView
                    android:id="@+id/textMisServicios"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mis Servicios"
                    android:textColor="@color/menu_text_color"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Opción para acceder al historial de servicios. -->
            <LinearLayout
                android:id="@+id/btnHistorial"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/iconHistorial"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/historial_icono"
                    android:contentDescription="Historial"
                    app:tint="@color/menu_icon_color" />

                <TextView
                    android:id="@+id/textHistorial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Historial"
                    android:textColor="@color/menu_text_color"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Opción para cerrar la sesión del usuario. -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/iconLogout"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/cerrar_sesion_icono"
                    android:contentDescription="Cerrar Sesión"
                    app:tint="@color/menu_icon_color" />

                <TextView
                    android:id="@+id/textLogout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cerrar Sesión"
                    android:textColor="@color/menu_text_color"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Línea divisoria entre el contenido de la aplicación y la barra de navegación del sistema. -->
    <View
        android:id="@+id/navBarDivider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#E0E0E0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Espacio reservado para evitar que el contenido sea cubierto por la barra de navegación del sistema. -->
    <Space
        android:id="@+id/navBarSpace"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/navBarDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
