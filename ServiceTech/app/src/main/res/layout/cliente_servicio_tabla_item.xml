<?xml version="1.0" encoding="utf-8"?>

<!--
    Muestra un resumen de cada servicio registrado por el cliente,
    presentando el tipo de servicio, una descripción breve y el
    estado actual mediante una etiqueta (badge).
-->

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <!--
        Contenedor principal que organiza la información del servicio
        en una sola fila utilizando pesos para distribuir el espacio.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:weightSum="4">

        <!-- Tipo del servicio solicitado -->
        <TextView
            android:id="@+id/txtTipo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="#1F2937"
            android:textStyle="bold"/>

        <!-- Descripción resumida del servicio -->
        <TextView
            android:id="@+id/txtDescripcion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:textSize="13sp"
            android:textColor="#4B5563"
            android:maxLines="2"
            android:ellipsize="end"
            android:paddingEnd="8dp"/>

        <!--
            Estado actual del servicio.
            El fondo del badge se actualiza dinámicamente desde el Adapter
            según el estado (Pendiente, En proceso, Finalizado o Cancelado).
        -->
        <TextView
            android:id="@+id/txtEstado"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="4dp"
            android:paddingHorizontal="8dp"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_estado_pendiente"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>